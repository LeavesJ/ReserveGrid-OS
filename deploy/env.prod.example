# Production environment template.
#
# Copy to .env (or mount via secrets manager) and fill every TODO field.
# The system will fail at startup if required values are missing.
#
# Key differences from .env.example (dev):
#   - No default credentials
#   - VELDRA_LOG_FORMAT=json (structured, not pretty)
#   - VELDRA_AUTH_TRUST_PROXY=1 (typical behind load balancer)
#   - VELDRA_MODE=inline (or observe for read-only evaluation)

# ── Deployment mode ──
VELDRA_MODE=inline

# ── Logging ──
VELDRA_LOG_FORMAT=json
VELDRA_LOG_FILTER=info

# ── Bitcoin Core ──
VELDRA_BITCOIND_RPC_USER=TODO_SET_RPC_USER
VELDRA_BITCOIND_RPC_PASS=TODO_SET_RPC_PASS

# ── API Authentication ──
# Generate with: reservegrid keygen
VELDRA_API_SECRET=TODO_SET_API_SECRET_MIN_32_HEX
VELDRA_API_SECRET_PREVIOUS=
VELDRA_HMAC_KEY=

# ── rg-auth ──
VELDRA_AUTH_ALLOWED_ORIGIN=TODO_SET_FRONTEND_ORIGIN
VELDRA_AUTH_SITE_URL=TODO_SET_FRONTEND_URL
VELDRA_AUTH_URL=TODO_SET_AUTH_SERVICE_URL
VELDRA_AUTH_TRUST_PROXY=1
VELDRA_AUTH_SESSION_TTL_HOURS=168
VELDRA_AUTH_RATE_MAX_IPS=10000
VELDRA_AUTH_RATE_GLOBAL_CEILING=

# ── SMTP (required for email verification) ──
VELDRA_AUTH_SMTP_HOST=TODO_SET_SMTP_HOST
VELDRA_AUTH_SMTP_PORT=587
VELDRA_AUTH_SMTP_USER=TODO_SET_SMTP_USER
VELDRA_AUTH_SMTP_PASS=TODO_SET_SMTP_PASS

# ── TLS ──
VELDRA_TLS_CERT=
VELDRA_TLS_KEY=
VELDRA_TLS_SELF_SIGNED=0
