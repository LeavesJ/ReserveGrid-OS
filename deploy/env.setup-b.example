# Setup B stack environment template.
#
# Copy to .env.setup-b at the repo root on the node and fill the password
# (the rpcauth.py plaintext, stored in 1Password). The file stays out of
# git; never commit a filled copy.
#
# Usage:
#   cp deploy/env.setup-b.example .env.setup-b
#   nano .env.setup-b
#   docker compose -f docker-compose.setup-b.yml --env-file .env.setup-b up -d --build

VELDRA_BITCOIND_RPC_USER=veldra
VELDRA_BITCOIND_RPC_PASS=TODO_PASTE_RPC_PASSWORD

# observe = read-only wiring validation. Flip to shadow for the soak,
# then run `up -d` again to recreate the stack in the new mode.
VELDRA_MODE=observe
