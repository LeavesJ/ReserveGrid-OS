# =============================================================================
# ReserveGrid OS — Environment Variables
# =============================================================================
# Copy to .env and fill in real values. Never commit .env to version control.
# Secrets come from environment or a secrets manager, never from TOML files.
# =============================================================================

# ── Bitcoin Core (regtest) ──
VELDRA_BITCOIND_RPC_USER=reservegrid
VELDRA_BITCOIND_RPC_PASS=

# ── pool-verifier ──
VELDRA_VERIFIER_ADDR=127.0.0.1:9090
VELDRA_HTTP_ADDR=127.0.0.1:8081
VELDRA_MEMPOOL_URL=http://127.0.0.1:8082/mempool
VELDRA_POLICY_FILE=./config/policy.toml

# ── template-manager ──
VELDRA_MANAGER_HTTP_ADDR=127.0.0.1:8082
VELDRA_MANAGER_CONFIG=./config/manager.toml

# ── TLS ──
# File-based TLS (production)
VELDRA_TLS_CERT=
VELDRA_TLS_KEY=
# Self-signed dev mode (set to 1 for local testing only)
VELDRA_TLS_SELF_SIGNED=0

# ── Authentication ──
# Primary API key (min 32 bytes hex, generated via `reservegrid keygen`)
VELDRA_API_SECRET=
# Previous API key (valid during rotation window, remove after rollover)
VELDRA_API_SECRET_PREVIOUS=
# HMAC signing key (when api_auth_mode = hmac_sha256)
VELDRA_HMAC_KEY=

# ── Logging ──
# Output format: "json" (production) or "pretty" (development)
VELDRA_LOG_FORMAT=pretty
# Per-module log filter (tracing EnvFilter syntax)
VELDRA_LOG_FILTER=info

# ── rg-auth ──
# These values are docker-compose-shape (bind 0.0.0.0:3030 inside the container,
# /data volume mount). For host-side `cargo run -p rg-auth` outside docker, use
# .env.local with host-shape overrides (127.0.0.1:8080, ./data/auth.db, multi-
# value CORS origin). See D-19 in docs/EXECLOG.md for the layered convention.
# Both .env and .env.local are gitignored under the .env.* pattern.
VELDRA_AUTH_ADDR=0.0.0.0:3030
VELDRA_AUTH_DB=/data/auth.db
VELDRA_AUTH_SITE_URL=http://localhost:8084
VELDRA_AUTH_ADMIN_EMAIL=admin@localhost
# CORS: comma-separated allowed origins (production: https://veldra.org).
# Wildcard "*" rejected. Multi-origin lets one rg-auth serve apex + www, or
# localhost + [::1] for local dev.
VELDRA_AUTH_ALLOWED_ORIGIN=http://localhost:8084
# Auth URL base for verification email links (production: https://auth.veldra.org)
VELDRA_AUTH_URL=http://localhost:3030
# Session lifetime in hours (default: 168 = 7 days)
VELDRA_AUTH_SESSION_TTL_HOURS=168
# Rate limiter: max tracked IPs before LRU eviction (default: 10000)
VELDRA_AUTH_RATE_MAX_IPS=10000
# Rate limiter: optional global requests per 60s window across all IPs (empty = disabled)
VELDRA_AUTH_RATE_GLOBAL_CEILING=
# Rate limiter: multiplier applied to all per-endpoint limits (default: 1)
# Set to 100 in integration test environments to avoid false 429s from rapid sequential requests.
VELDRA_AUTH_RATE_LIMIT_MULTIPLIER=1
# Trust X-Forwarded-For header for client IP extraction (set to 1 behind a trusted reverse proxy)
VELDRA_AUTH_TRUST_PROXY=0
# SMTP (leave blank to disable; emails print to stdout in dev mode)
VELDRA_AUTH_SMTP_HOST=
VELDRA_AUTH_SMTP_PORT=587
VELDRA_AUTH_SMTP_USER=
VELDRA_AUTH_SMTP_PASS=
# Optional: sender address (defaults to SMTP_USER if unset)
VELDRA_AUTH_SMTP_FROM=

# ── License Keys (Ed25519 signed veldra_lic_ format) ──
# 32-byte Ed25519 seed, base64url encoded. Required for rg-auth to generate
# signed license keys. Must be a Fly/Vault secret in production.
VELDRA_LICENSE_SIGNING_KEY=
# 32-byte Ed25519 public key, base64url encoded. Derived from the signing key.
# Used by rg-feed-server and rg-desktop for offline key verification.
VELDRA_LICENSE_PUBKEY=

# ── Deploy Mode ──
# Controls which features are active: shadow, observe, inline.
# The main docker-compose.yml is the inline stack. Shadow and observe
# have dedicated compose files that override this value.
VELDRA_MODE=inline

# ── rg-demo-feed (shadow mode) ──
VELDRA_DEMO_FEED_LISTEN=0.0.0.0:9100
VELDRA_DEMO_FEED_INTERVAL_MS=5000

# ── rg-feed-adapter ──
VELDRA_ADAPTER_LISTEN=127.0.0.1:18444
VELDRA_FEED_URL=ws://127.0.0.1:9100/ws
# License key for observe mode (empty = unauthenticated, for shadow/demo use)
VELDRA_FEED_LICENSE_KEY=

# ── rg-feed-server (observe mode, Veldra-hosted) ──
VELDRA_FEED_LISTEN=0.0.0.0:9200
VELDRA_FEED_RPC_URL=
VELDRA_FEED_RPC_USER=
VELDRA_FEED_RPC_PASS=
VELDRA_FEED_POLL_INTERVAL_MS=3000
# Comma-separated static key list (dev only); production uses rg-auth
VELDRA_FEED_VALID_KEYS=
# rg-auth URL for dynamic key validation (production)
VELDRA_FEED_AUTH_URL=

# ── Gateway (v1.0.0) ──
VELDRA_GATEWAY_ADDR=127.0.0.1:3333
VELDRA_GATEWAY_CONFIG=./config/gateway.toml
# Unique instance identifier (auto-generated from hostname if unset)
VELDRA_GATEWAY_INSTANCE_ID=
# Template manager URL (gateway fetches templates from here)
VELDRA_TEMPLATE_URL=http://127.0.0.1:8082
# Share upstream secret for authenticated relay
VELDRA_SHARE_UPSTREAM_SECRET=
# NDJSON share log path (empty = disabled)
VELDRA_SHARE_LOG_PATH=
# Data directory for WAL and state files
VELDRA_DATA_DIR=./data

# ── Gateway Deployment Escape Hatches (development only) ──
# Allow drop_old in inline mode (default: 0, rejected in production)
VELDRA_ALLOW_DROP_OLD_INLINE=0
# Allow remote verifier without mTLS (default: 0)
VELDRA_ALLOW_REMOTE_VERIFIER=0
# Allow insecure verifier connection (default: 0)
VELDRA_ALLOW_INSECURE_VERIFIER=0

# ── sv2-bridge (development / testing synthetic template source) ──
# Listen address for the synthetic bridge
VELDRA_BRIDGE_ADDR=127.0.0.1:3333
# Interval between synthetic template emissions (seconds)
VELDRA_BRIDGE_INTERVAL_SECS=5
# Initial block height for synthetic templates
VELDRA_BRIDGE_START_HEIGHT=500
# Number of transactions per synthetic template
VELDRA_BRIDGE_TX_COUNT=5
# Total fees in satoshis per synthetic template
VELDRA_BRIDGE_TOTAL_FEES=100
# Override block subsidy in satoshis (computed from height if unset)
VELDRA_BRIDGE_SUBSIDY_SATS=

# ── Verifier TLS (remote verifier mTLS, see PRODUCTION_BLOCKERS.md PB-3) ──
# Leave blank for loopback-only deployments
VELDRA_VERIFIER_TLS_CERT=
VELDRA_VERIFIER_TLS_KEY=
VELDRA_VERIFIER_TLS_CLIENT_CA=
